# API Keys
OPENAI_API_KEY=your_openai_api_key_here
GOOGLE_API_KEY=your_gemini_api_key_here
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# App Settings
APP_NAME="Informal Service Orchestrator"
DEBUG=true
PORT=8000
ALLOWED_ORIGINS=*

# Database (Phase 4)
# Set USE_REAL_DB=true to switch from in-memory MockDB to PostgreSQL
USE_REAL_DB=false
# PostgreSQL connection string (used only when USE_REAL_DB=true)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/informal_services
